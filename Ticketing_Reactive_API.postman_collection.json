{
  "info": {
    "name": "Ticketing Reactive API",
    "description": "Postman Collection for the Reactive Event Ticketing API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Event",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Tech Conference 2026\",\n    \"date\": \"2026-10-15T09:00:00\",\n    \"location\": \"Convention Center\",\n    \"totalCapacity\": 500\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/events",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "events"
          ]
        }
      }
    },
    {
      "name": "Get All Events",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/events",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "events"
          ]
        }
      }
    },
    {
      "name": "Get Event Availability",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/events/{{event_id}}/availability",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "events",
            "{{event_id}}",
            "availability"
          ]
        }
      }
    },
    {
      "name": "Purchase/Reserve Tickets",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"userId\": \"user-789\",\n    \"quantity\": 2\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/events/{{event_id}}/purchase",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "events",
            "{{event_id}}",
            "purchase"
          ]
        }
      }
    },
    {
      "name": "Check Order Status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/orders/{{order_id}}",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "orders",
            "{{order_id}}"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "event_id",
      "value": "replace-with-actual-event-id"
    },
    {
      "key": "order_id",
      "value": "replace-with-actual-order-id"
    }
  ]
}
